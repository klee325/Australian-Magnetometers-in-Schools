import time
import numpy as np
import matplotlib.pyplot as plt
from ADCDifferentialPi import ADCDifferentialPi

SENSITIVITY = 50  # µT per volt

# Offsets (adjust after calibration)
OFFSET_1 = 0.0
OFFSET_2 = 0.0
OFFSET_3 = 0.0

values1 = []
values2 = []
values3 = []
values_total = []
times = []

start_time = time.time()


adc = ADCDifferentialPi(0x68, 0x69, 18)

while True:
    current_time = time.time() - start_time

    # Read voltages and convert to µT
    bx = (adc.read_voltage(1) - OFFSET_1) * SENSITIVITY
    by = (adc.read_voltage(2) - OFFSET_2) * SENSITIVITY
    bz = (adc.read_voltage(3) - OFFSET_3) * SENSITIVITY

    # Total magnetic field
    b_total = np.sqrt(bx**2 + by**2 + bz**2)

    # Store values
    values1.append(bx)
    values2.append(by)
    values3.append(bz)
    values_total.append(b_total)
    times.append(current_time)

    # Plotting
    plt.clf()
    plt.plot(times, values1, label='Bx (µT)')
    plt.plot(times, values2, label='By (µT)')
    plt.plot(times, values3, label='Bz (µT)')
    plt.plot(times, values_total, label='Total Field (µT)', linewidth=2)

    plt.xlabel('Time (s)')
    plt.ylabel('Magnetic Field (µT)')
    plt.legend()
    plt.pause(0.01)

    time.sleep(0.1)
